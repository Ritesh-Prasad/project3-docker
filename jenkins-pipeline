pipeline {
agent any

tools {
    jdk 'jdk18'
    nodejs 'node20'
}

environment {
    SCANNER_HOME = tool 'mysonar'
}

stages {

    stage('Clean Workspace') {
        steps {
            cleanWs()
        }
    }

    stage('Checkout Code') {
        steps {
            git 'https://github.com/devops0014/Zomato-Project.git'
        }
    }

    stage('Install Dependencies') {
        steps {
            sh 'npm install'
        }
    }

    stage('SonarQube Analysis') {
        steps {
            withSonarQubeEnv('mysonar') {
                sh """
                    $SCANNER_HOME/bin/sonar-scanner \
                    -Dsonar.projectName=zomato \
                    -Dsonar.projectKey=zomato
                """
            }
        }
    }

    stage('Quality Gate') {
        steps {
            script {
                waitForQualityGate abortPipeline: false, credentialsId: 'sonar-token'
            }
        }
    }

    /*
    stage('OWASP Dependency Check') {
        steps {
            dependencyCheck(
                additionalArguments: '--scan ./ --disableYarnAudit --disableNodeAudit',
                odcInstallation: 'DP-Check'
            )*/

         //   dependencyCheckPublisher(
              //  pattern: '**/dependency-check-report.xml'
           // )
     //   }
   // } 

    stage('Trivy File System Scan') {
        steps {
            sh 'trivy fs . > trivyfs.txt'
        }
    }

    stage('Build Docker Image') {
        steps {
            sh 'docker build -t image1 .'
        }
    }

    stage('Tag & Push Image') {
        steps {
            script {
                withDockerRegistry(credentialsId: 'docker-password', url: 'https://index.docker.io/v1/') {
                    sh 'docker tag image1 riteshprasad07/mydockerproject:myzomatoimage'
                    sh 'docker push riteshprasad07/mydockerproject:myzomatoimage'
                }
            }
        }
    }

    stage('Trivy Image Scan') {
        steps {
            sh 'trivy image riteshprasad07/mydockerproject:myzomatoimage'
        }
    }

    stage('Run Container') {
        steps {
            sh 'docker run -d --name cont1 -p 3000:3000 riteshprasad07/mydockerproject:myzomatoimage'
        }
    }

}
}
